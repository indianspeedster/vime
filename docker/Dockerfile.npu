ARG BASE_IMAGE=registry-cbu.huawei.com/atelier/verl:verl_0.8.0-vllm_0.17.0-mindspeed_0.16.0-pytorch_2.9.0-cann_8.5.2-py_3.11-hce_2.0.2512-aarch64-snt9b-20260513174224-90d255f
FROM ${BASE_IMAGE}

ARG PATCH_VERSION=latest

WORKDIR /home/ma-user

COPY docker/patch/${PATCH_VERSION}/megatron-all-changes.patch /tmp/megatron-all-changes.patch
RUN cd Megatron-LM && \
    git update-index --refresh || true && \
    git apply --3way /tmp/megatron-all-changes.patch || true && \
    if grep -R -n '^<<<<<<< ' megatron/; then \
      echo "Patch conflicts detected. Please resolve." && exit 1; \
    fi && \
    pip install -e . --no-build-isolation --no-deps

COPY docker/patch/${PATCH_VERSION}/vllm.patch /tmp/vllm.patch
RUN cd vllm && \
    git apply /tmp/vllm.patch

COPY docker/patch/${PATCH_VERSION}/vllm-ascend.patch /tmp/vllm-ascend.patch
RUN cd vllm-ascend && \
    git apply /tmp/vllm-ascend.patch

COPY docker/patch/${PATCH_VERSION}/mindspeed.patch /tmp/mindspeed.patch
RUN cd MindSpeed && \
    git apply --3way /tmp/mindspeed.patch || true && \
    if grep -R -n '^<<<<<<< ' mindspeed/; then \
      echo "MindSpeed patch conflicts detected." && exit 1; \
    fi

COPY docker/patch/${PATCH_VERSION}/torch_npu.patch /tmp/torch_npu.patch
RUN TORCH_NPU_DIR=$(python3 -c "import importlib.util; print(importlib.util.find_spec('torch_npu').submodule_search_locations[0])") && \
    cd ${TORCH_NPU_DIR} && \
    patch -p2 < /tmp/torch_npu.patch || echo "torch_npu patch skipped (version mismatch)"

COPY . /home/ma-user/vime/
RUN git config --global --add safe.directory /home/ma-user/vime && \
    cd /home/ma-user/vime && \
    pip install -e . --no-deps --no-build-isolation

ENV PYTHONPATH=/home/ma-user/Megatron-LM:/home/ma-user/vllm:/home/ma-user/vime:${PYTHONPATH}
ENV CUDA_DEVICE_MAX_CONNECTIONS=1

ENTRYPOINT []
CMD ["/bin/bash"]
